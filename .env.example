# Compose host-side settings (used by docker compose interpolation)
REPOS_HOST_PATH=./watched-repos
GHCR_OWNER=sirnacou
IMAGE_TAG=latest

# Application runtime settings (passed into the container)
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openrouter/free
REPOS_ROOT=/repos
SCAN_INTERVAL_MINUTES=15
BRANCH_ALLOWLIST=main,develop,feature/*
GIT_AUTHOR_NAME=autocommit-bot
GIT_AUTHOR_EMAIL=bot@example.com
COMMIT_POLICY=safe
RUN_TESTS_CMD=
MAX_DIFF_CHARS=12000
STATE_DB_PATH=/data/state.db
LOG_LEVEL=INFO
PUSH_ENABLED=true
HEALTH_PORT=8080
REPO_TIMEOUT_SECONDS=120
